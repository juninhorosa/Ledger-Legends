modules = ["nodejs-20", "python-3.12", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["libxcrypt"]

[userenv]

[userenv.shared]
MONGO_URL = "mongodb://localhost:27017"
DB_NAME = "chronicles_of_ton"
REACT_APP_BACKEND_URL = "http://localhost:8000"
PORT = "5000"
HOST = "0.0.0.0"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && ./node_modules/.bin/craco start"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "mkdir -p /tmp/mongodb/data && mongod --dbpath /tmp/mongodb/data --port 27017 --fork --logpath /tmp/mongodb/mongo.log 2>/dev/null; sleep 2 && cd backend && python -m uvicorn server:app --host 0.0.0.0 --port 8000 --reload"
waitForPort = 8000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd backend && python -m uvicorn server:app --host 0.0.0.0 --port 8000"]
build = ["bash", "-c", "cd frontend && npm run build"]
